# Zkopíruj tento soubor na  .env  a vyplň své hodnoty.
#   cp .env.example .env        (Mac/Linux)
#   copy .env.example .env      (Windows)
#
# Jak získat token a chat_id je krok za krokem popsané v README.md (sekce "Telegram").

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM zpracování inzerátů (spolehlivé poplatky/energie z popisu) ---
# Stačí JEDEN klíč. Priorita: Gemini > OpenAI > Groq. Bez klíče se LLM přeskočí.
# Gemini (doporučeno, štědrý free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternativy (nepovinné):
# OPENAI_API_KEY=
# GROQ_API_KEY=
# Volitelně vlastní model (jinak rozumný default podle poskytovatele):
# LLM_MODEL=
